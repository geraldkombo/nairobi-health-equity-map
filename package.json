{
  "name": "kenya-health-equity-map",
  "version": "1.0.0",
  "private": true,
  "description": "Map-first civic intelligence platform for health equity across Kenya's 47 counties",
  "repository": "github.com/geraldkombo/kenya-health-equity-map",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const s='./data';const d='./public/data';fs.rmSync(d,{recursive:true,force:true});fs.cpSync(s,d,{recursive:true})\"",
    "dev": "node -e \"const fs=require('fs');const s='./data';const d='./public/data';fs.rmSync(d,{recursive:true,force:true});fs.cpSync(s,d,{recursive:true})\" && next dev",
    "build": "next build",
    "start": "npx serve out",
    "etl:extract": "npx tsx scripts/etl/1-extract-kmhfr.ts",
    "etl:knbs": "npx tsx scripts/etl/2-extract-knbs.ts",
    "etl:spatial": "npx tsx scripts/etl/3-extract-spatial.ts",
    "etl:build": "npx tsx scripts/etl/4-build-snapshot.ts",
    "etl": "npm run etl:extract && npm run etl:knbs && npm run etl:spatial && npm run etl:build",
    "lint": "next lint",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@turf/turf": "^7.3.5",
    "csv-parse": "^6.2.1",
    "echarts": "5.5.1",
    "echarts-for-react": "3.0.2",
    "fuse.js": "^7.4.2",
    "maplibre-gl": "4.7.1",
    "next": "15.2.4",
    "pmtiles": "^4.4.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-to-print": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "1.52.0",
    "@tailwindcss/postcss": "4.1.6",
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.26.0",
    "eslint-config-next": "15.2.4",
    "husky": "^9.1.7",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "4.1.6",
    "tsx": "^4.22.4",
    "typescript": "5.8.3"
  }
}
