{
  "name": "kenya-health-equity-map",
  "version": "1.0.0",
  "private": true,
  "description": "Map-first civic intelligence platform for health equity across Kenya's 47 counties",
  "repository": "github.com/geraldkombo/kenya-health-equity-map",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "node -e \"const fs=require('fs');const s='./data';const d='./public/data';fs.rmSync(d,{recursive:true,force:true});fs.cpSync(s,d,{recursive:true})\"",
    "dev": "node -e \"const fs=require('fs');const s='./data';const d='./public/data';fs.rmSync(d,{recursive:true,force:true});fs.cpSync(s,d,{recursive:true})\" && next dev",
    "build": "next build",
    "start": "npx serve out",
    "etl:fetch": "npx tsx scripts/etl/fetch-knbs.ts",
    "etl:aggregate": "npx tsx scripts/etl/aggregate-wards.ts",
    "etl:build": "npx tsx scripts/etl/build-snapshots.ts",
    "postetl": "node -e \"const fs=require('fs');const s='./data/snapshots';const d='./public/data/snapshots';if(!fs.existsSync(d)){fs.mkdirSync(d,{recursive:true})};fs.readdirSync(s).forEach(f=>fs.copyFileSync(s+'/'+f,d+'/'+f))\"",
    "etl": "npm run etl:fetch && npm run etl:aggregate && npm run etl:build && npm run postetl",
    "lint": "next lint",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "echarts": "5.5.1",
    "echarts-for-react": "3.0.2",
    "maplibre-gl": "4.7.1",
    "next": "15.2.4",
    "pmtiles": "^4.4.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-to-print": "^3.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "1.52.0",
    "@tailwindcss/postcss": "4.1.6",
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.26.0",
    "eslint-config-next": "15.2.4",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "4.1.6",
    "typescript": "5.8.3"
  }
}
