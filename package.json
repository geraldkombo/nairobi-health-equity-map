{
  "name": "kenya-health-equity-map",
  "version": "1.0.0",
  "private": true,
  "description": "Map-first civic intelligence platform for health equity across Kenya's 47 counties",
  "repository": "github.com/geraldkombo/kenya-health-equity-map",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "prebuild": "node -e \"if(!require('fs').existsSync('./public/data')){require('fs').cpSync('./data','./public/data',{recursive:true})}\"",
    "dev": "node -e \"if(!require('fs').existsSync('./public/data')){require('fs').cpSync('./data','./public/data',{recursive:true})}\" && next dev",
    "build": "next build",
    "start": "npx serve out",
    "lint": "next lint",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "echarts": "5.5.1",
    "echarts-for-react": "3.0.2",
    "maplibre-gl": "4.7.1",
    "next": "15.2.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@netlify/functions": "^5.3.0",
    "@playwright/test": "1.52.0",
    "@tailwindcss/postcss": "4.1.6",
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "eslint": "9.26.0",
    "eslint-config-next": "15.2.4",
    "postcss": "8.5.3",
    "prettier": "3.5.3",
    "tailwindcss": "4.1.6",
    "typescript": "5.8.3"
  }
}
